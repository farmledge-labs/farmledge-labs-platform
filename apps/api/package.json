{
  "name": "@farmledge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "node --env-file=.env --import=tsx --test tests/health.test.ts tests/routes.test.ts tests/auth.test.ts tests/api-key.test.ts tests/jwt.test.ts tests/env.test.ts tests/schemas.test.ts tests/bagSizes.test.ts tests/uploads.test.ts tests/utils/formatters.test.ts tests/utils/response.test.ts tests/middleware/error.test.ts",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@farmledge/shared": "*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^5.22.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^9.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "prisma": "^5.22.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
